# DGX Spark Hackathon - 环境变量配置
# 复制此文件为 .env 并填入实际值

# ===== Stepfun 阶跃星辰 =====
STEPFUN_API_KEY=your_stepfun_api_key_here
STEPFUN_BASE_URL=https://api.stepfun.com/v1
STEPFUN_MODEL=step-3.7-flash

# ===== NVIDIA Nemotron (本地推理后备) =====
NEMOTRON_MODEL_PATH=/models/nemotron-4-mini
NEMOTRON_ENGINE_PATH=/models/nemotron-4-mini/trt_engine

# ===== DGX Spark 云节点 =====
DGX_SPARK_HOST=your_dgx_spark_ip
DGX_SPARK_PORT=8000

# ===== 服务配置 =====
HOST=0.0.0.0
PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# ===== ChromaDB =====
CHROMA_PERSIST_DIR=./data/chroma_db
